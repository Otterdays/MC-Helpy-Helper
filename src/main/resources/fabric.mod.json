{
  "schemaVersion": 1,
  "id": "fpsmod",
  "version": "${version}",
  "name": "FPS Mod",
  "description": "Lightweight FPS counter on the HUD (1s refresh) with a simple show/hide toggle.",
  "authors": [
    "otterdays"
  ],
  "contact": {
    "homepage": "https://github.com/Otterdays/Minecraft-Fabric-Sample-Mod",
    "sources": "https://github.com/Otterdays/Minecraft-Fabric-Sample-Mod",
    "issues": "https://github.com/Otterdays/Minecraft-Fabric-Sample-Mod/issues"
  },
  "license": "LicenseRef-All-Rights-Reserved",
  "icon": "assets/fpsmod/icon.png",
  "environment": "client",
  "entrypoints": {
    "main": [
      "com.fpsmod.FpsMod"
    ],
    "client": [
      "com.fpsmod.FpsModClient"
    ]
  },
  "depends": {
    "fabricloader": ">=0.19.2",
    "minecraft": "~26.1.2",
    "java": ">=25",
    "fabric-api": "*"
  },
  "suggests": {
    "modmenu": "*"
  }
}
