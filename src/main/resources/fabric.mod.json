{
  "schemaVersion": 1,
  "id": "helphelper",
  "version": "${version}",
  "name": "Help Helper",
  "description": "Opens a full-window, searchable Minecraft-styled GUI when using /help, listing commands you can click to run.",
  "authors": [
    "Otterdays"
  ],
  "contact": {
    "homepage": "https://github.com/Otterdays/MC-Helpy-Helper",
    "sources": "https://github.com/Otterdays/MC-Helpy-Helper",
    "issues": "https://github.com/Otterdays/MC-Helpy-Helper/issues"
  },
  "license": "LicenseRef-All-Rights-Reserved",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.otterdays.helphelper.HelpHelper"
    ],
    "client": [
      "com.otterdays.helphelper.client.HelpHelperClient"
    ]
  },
  "depends": {
    "fabricloader": ">=0.19.2",
    "minecraft": "~26.1.2",
    "java": ">=25",
    "fabric-api": "*"
  },
  "suggests": {
    "modmenu": "*"
  }
}
